{
  "name": "om-x",
  "productName": "Om-X",
  "version": "2.0.5",
  "description": "Om-X - AI Browser with Minecraft Server Integration",
  "main": "main.js",
  "author": "Sk Abdul Ramiz",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ramizsk586/Om-X.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "workspaces": [
    "tools/ddg",
    "tools/wiki"
  ],
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@lmstudio/sdk": "^1.5.0",
    "electron-updater": "^6.8.3",
    "eliza": "^0.0.1-2",
    "express": "^5.2.1",
    "groq-sdk": "^0.37.0",
    "jspdf": "^4.2.0",
    "minecraft-data": "^3.105.0",
    "mineflayer": "^4.35.0",
    "mineflayer-collectblock": "^1.6.0",
    "mineflayer-pathfinder": "^2.4.5",
    "sarvamai": "^1.1.4",
    "socket.io": "^4.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.omx.browser",
    "productName": "Om-X.browser",
    "protocols": [
      {
        "name": "HTTP Protocol",
        "schemes": [
          "http",
          "https"
        ]
      }
    ],
    "fileAssociations": [
      {
        "ext": [
          "html",
          "htm",
          "shtml",
          "xhtml"
        ],
        "name": "HTML Document",
        "role": "Viewer",
        "mimeType": "text/html"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Ramizsk586",
        "repo": "Om-X"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!**/*.ts",
      "!**/*.map"
    ],
    "asarUnpack": [
      "java/extension/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/app.ico",
      "legalTrademarks": "Om-X Browser"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Om-X",
      "deleteAppDataOnUninstall": false,
      "perMachine": false
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/app.icns",
      "category": "public.app-category.productivity",
      "extendInfo": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "Web URL",
            "CFBundleURLSchemes": [
              "http",
              "https"
            ]
          }
        ]
      }
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icons/icon.png",
      "category": "WebBrowser",
      "mimeTypes": [
        "text/html",
        "x-scheme-handler/http",
        "x-scheme-handler/https"
      ]
    }
  }
}
