{
  "name": "chessly",
  "productName": "Chessly",
  "version": "1.1.1",
  "description": "Next-gen chess GUI for Om-X with AI Arena, LAN Arena, and deep analysis tools",
  "main": "java/main.js",
  "author": "Sk Abdul Ramiz",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Ramizsk586/Om-X.git"
  },
  "keywords": [
    "chess",
    "electron",
    "ai",
    "lan",
    "om-x"
  ],
  "scripts": {
    "start": "powershell -Command \"Remove-Item Env:ELECTRON_RUN_AS_NODE -ErrorAction SilentlyContinue; & ..\\..\\..\\node_modules\\.bin\\electron.cmd .\"",
    "build": "powershell -Command \"& ..\\..\\..\\node_modules\\.bin\\electron-builder.cmd --projectDir .\"",
    "pack": "powershell -Command \"& ..\\..\\..\\node_modules\\.bin\\electron-builder.cmd --projectDir . --dir\"",
    "check:syntax": "powershell -Command \"Get-ChildItem .\\java -Filter *.js -Recurse | ForEach-Object { node --check \\\"$($_.FullName)\\\" }\""
  },
  "build": {
    "appId": "com.chessly.app",
    "directories": {
      "output": "dist",
      "buildResources": "assets/icon"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!public/**",
      "!**/*.ts",
      "!**/*.map"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon/chessly.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon/chessly.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon/chessly.png"
    }
  }
}
